# Normalise line endings to LF on checkout (Docker/Linux target).
* text=auto eol=lf

# Scripts and configs MUST stay LF (CRLF breaks shebangs / nginx / php-fpm).
*.sh        text eol=lf
*.conf      text eol=lf
Dockerfile  text eol=lf
Makefile    text eol=lf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.avif binary
*.ico binary
*.woff binary
*.woff2 binary
