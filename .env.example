# =============================================================================
# Kielkraft - environment template
# Copy to ".env" (never commit .env) and fill in real values.
#   cp .env.example .env
# In production these values are injected on the Hetzner server / via GitHub
# Actions Secrets, NOT baked into the image.
# =============================================================================

# --- App ---------------------------------------------------------------------
APP_ENV=development                 # development | production
APP_URL=http://localhost:8080       # canonical base URL (used for sitemap, hreflang, OG)
KIRBY_DEBUG=true                    # MUST be false in production
KIRBY_CACHE=false                   # pages cache; true in production

# --- Local ports (docker-compose dev) ---------------------------------------
WEB_PORT=8080                       # http://localhost:8080  -> shop
MAILPIT_UI_PORT=8025                # http://localhost:8025  -> caught e-mails

# --- Stripe (payment layer) --------------------------------------------------
# Test keys for dev (sk_test_... / pk_test_...). Webhooks REQUIRED.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Invoicing backend (choose ONE; lexoffice recommended) -------------------
INVOICE_PROVIDER=fallback           # lexoffice | sevdesk | fallback (in-house PDF)
LEXOFFICE_API_KEY=
SEVDESK_API_TOKEN=

# --- Transactional e-mail (ESP - NEVER use PHP mail()) -----------------------
# Local dev uses Mailpit (smtp host "mailpit", port 1025, no auth).
MAIL_TRANSPORT=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_SECURITY=                      # tls | ssl | (empty for mailpit)
MAIL_FROM=bestellung@kielkraft.de
MAIL_FROM_NAME=Kielkraft
MAIL_REPLY_TO=info@kielkraft.de
MAIL_CONTACT_TO=info@boostboards.de  # inbox for contact + order notifications

# --- Dropshipping partner routing -------------------------------------------
PARTNER_ORDER_BCC=bestellung@kielkraft.de

# --- Security ----------------------------------------------------------------
# Used to harden the Panel / forms. Generate with: openssl rand -hex 32
APP_SECRET=

# --- Analytics (consent-gated) ----------------------------------------------
MATOMO_URL=
MATOMO_SITE_ID=
